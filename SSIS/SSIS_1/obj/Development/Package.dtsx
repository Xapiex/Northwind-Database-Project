    <DTS:Executable
      DTS:refId="Package\Load DW from Staging"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{05B39C40-D729-49EE-96CB-1018F546C7EF}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DW from Staging"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{222FCD21-D842-4BCC-93CD-DB4D45FC76A7}"
          SQLTask:SqlStatementSource="-- Load DimCustomer&#xA;MERGE Northwind_DW.dbo.DimCustomer AS target&#xA;USING Northwind_Staging.dbo.STG_Customers AS source&#xA;ON target.CustomerID = source.CustomerID&#xA;WHEN MATCHED THEN&#xA;    UPDATE SET&#xA;        target.CompanyName  = source.CompanyName,&#xA;        target.ContactName  = source.ContactName,&#xA;        target.City         = source.City,&#xA;        target.Country      = source.Country,&#xA;        target.Phone        = source.Phone&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (CustomerID, CompanyName, ContactName, City, Country, Phone)&#xA;    VALUES (source.CustomerID, source.CompanyName, source.ContactName,&#xA;            source.City, source.Country, source.Phone);&#xA;&#xA;-- Load DimProduct&#xA;MERGE Northwind_DW.dbo.DimProduct AS target&#xA;USING (&#xA;    SELECT&#xA;        s.ProductID,&#xA;        s.ProductName,&#xA;        c.CategoryName,&#xA;        sup.CompanyName AS SupplierName,&#xA;        s.UnitPrice,&#xA;        s.Discontinued&#xA;    FROM Northwind_Staging.dbo.STG_Products s&#xA;    LEFT JOIN Northwind_OLTP.dbo.Categories c   ON s.CategoryID  = c.CategoryID&#xA;    LEFT JOIN Northwind_OLTP.dbo.Suppliers sup  ON s.SupplierID  = sup.SupplierID&#xA;) AS source&#xA;ON target.ProductID = source.ProductID&#xA;WHEN MATCHED THEN&#xA;    UPDATE SET&#xA;        target.ProductName  = source.ProductName,&#xA;        target.CategoryName = source.CategoryName,&#xA;        target.SupplierName = source.SupplierName,&#xA;        target.UnitPrice    = source.UnitPrice,&#xA;        target.Discontinued = source.Discontinued&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (ProductID, ProductName, CategoryName, SupplierName, UnitPrice, Discontinued)&#xA;    VALUES (source.ProductID, source.ProductName, source.CategoryName,&#xA;            source.SupplierName, source.UnitPrice, source.Discontinued);&#xA;&#xA;-- Load DimEmployee&#xA;MERGE Northwind_DW.dbo.DimEmployee AS target&#xA;USING (&#xA;    SELECT&#xA;        e.EmployeeID,&#xA;        e.FirstName + ' ' + e.LastName     AS FullName,&#xA;        e.Title,&#xA;        e.City,&#xA;        e.Country,&#xA;        m.FirstName + ' ' + m.LastName     AS ReportsToName&#xA;    FROM Northwind_Staging.dbo.STG_Employees e&#xA;    LEFT JOIN Northwind_OLTP.dbo.Employees m ON e.ReportsTo = m.EmployeeID&#xA;) AS source&#xA;ON target.EmployeeID = source.EmployeeID&#xA;WHEN MATCHED THEN&#xA;    UPDATE SET&#xA;        target.FullName      = source.FullName,&#xA;        target.Title         = source.Title,&#xA;        target.City          = source.City,&#xA;        target.Country       = source.Country,&#xA;        target.ReportsToName = source.ReportsToName&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (EmployeeID, FullName, Title, City, Country, ReportsToName)&#xA;    VALUES (source.EmployeeID, source.FullName, source.Title,&#xA;            source.City, source.Country, source.ReportsToName);&#xA;&#xA;-- Load FactSales from STG_Orders and STG_OrderDetails&#xA;MERGE Northwind_DW.dbo.FactSales AS target&#xA;USING (&#xA;    SELECT&#xA;        CAST(FORMAT(o.OrderDate, 'yyyyMMdd') AS INT)            AS DateKey,&#xA;        dc.CustomerKey,&#xA;        dp.ProductKey,&#xA;        de.EmployeeKey,&#xA;        dg.GeographyKey,&#xA;        o.OrderID,&#xA;        od.Quantity,&#xA;        od.UnitPrice,&#xA;        od.Discount,&#xA;        o.Freight,&#xA;        CAST(od.UnitPrice * od.Quantity * (1 - od.Discount) &#xA;             AS MONEY)                                          AS Revenue&#xA;    FROM Northwind_Staging.dbo.STG_OrderDetails od&#xA;    JOIN Northwind_Staging.dbo.STG_Orders o&#xA;        ON od.OrderID = o.OrderID&#xA;    JOIN Northwind_DW.dbo.DimCustomer dc&#xA;        ON o.CustomerID = dc.CustomerID&#xA;    JOIN Northwind_DW.dbo.DimProduct dp&#xA;        ON od.ProductID = dp.ProductID&#xA;    JOIN Northwind_DW.dbo.DimEmployee de&#xA;        ON o.EmployeeID = de.EmployeeID&#xA;    JOIN Northwind_DW.dbo.DimGeography dg&#xA;        ON dg.GeographyKey = (&#xA;            SELECT TOP 1 dg2.GeographyKey&#xA;            FROM Northwind_OLTP.dbo.ShippingAddresses sa&#xA;            JOIN Northwind_DW.dbo.DimGeography dg2&#xA;                ON sa.ShipCity    = dg2.ShipCity&#xA;                AND sa.ShipCountry = dg2.ShipCountry&#xA;            WHERE sa.ShipAddressID = o.ShipAddressID&#xA;        )&#xA;) AS source&#xA;ON target.OrderID = source.OrderID&#xA;AND target.ProductKey = source.ProductKey&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (DateKey, CustomerKey, ProductKey, EmployeeKey, GeographyKey,&#xA;            OrderID, Quantity, UnitPrice, Discount, Freight, Revenue)&#xA;    VALUES (source.DateKey, source.CustomerKey, source.ProductKey,&#xA;            source.EmployeeKey, source.GeographyKey, source.OrderID,&#xA;            source.Quantity, source.UnitPrice, source.Discount,&#xA;            source.Freight, source.Revenue);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
