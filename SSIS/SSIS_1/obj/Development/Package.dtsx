      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{222FCD21-D842-4BCC-93CD-DB4D45FC76A7}"
          SQLTask:SqlStatementSource="UPDATE ETL_Control&#xA;SET &#xA;    LastRowVersion = (SELECT MAX(rowversion_col) FROM Northwind_OLTP.dbo.Orders),&#xA;    LastLoadDate   = GETDATE()&#xA;WHERE TableName = 'Orders';&#xA;&#xA;UPDATE ETL_Control&#xA;SET &#xA;    LastRowVersion = (SELECT MAX(rowversion_col) FROM Northwind_OLTP.dbo.Customers),&#xA;    LastLoadDate   = GETDATE()&#xA;WHERE TableName = 'Customers';&#xA;&#xA;UPDATE ETL_Control&#xA;SET &#xA;    LastRowVersion = (SELECT MAX(rowversion_col) FROM Northwind_OLTP.dbo.Products),&#xA;    LastLoadDate   = GETDATE()&#xA;WHERE TableName = 'Products';&#xA;&#xA;UPDATE ETL_Control&#xA;SET &#xA;    LastRowVersion = (SELECT MAX(rowversion_col) FROM Northwind_OLTP.dbo.Employees),&#xA;    LastLoadDate   = GETDATE()&#xA;WHERE TableName = 'Employees';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
